{
  "expo": {
    "name": "Nómada.AI",
    "slug": "nomadaai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nomadaai",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "ai.nomada.app"
    },
    "android": {
      "package": "ai.nomada.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B101A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B101A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Nómada.AI usa tu ubicación para mostrarte en el mapa y guiarte por la ruta más segura.",
          "locationAlwaysAndWhenInUsePermission": "Con «Permitir siempre», Nómada.AI detecta cuando empiezas a moverte y activa tu protección automáticamente. Solo se usa para cuidarte en el camino.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
